# 🌐 第四区：FastAPI 启动与生命周期挂载
# ==========================================
@asynccontextmanager
async def lifespan(app: FastAPI):
    scheduler = BackgroundScheduler()
    # 每天早上 8:00 准时出击
    scheduler.add_job(autonomous_briefing_task, 'cron', hour=8, minute=0)
    scheduler.start()
    logger.info("⏳ 心脏起搏器已点火！情报刺客进入【每天早 8:00】长线潜伏模式！")
    yield
    scheduler.shutdown()


app = FastAPI(lifespan=lifespan)
app.add_middleware(CORSMiddleware, allow_origins=["*"], allow_methods=["*"], allow_headers=["*"])


class ChatRequest(BaseModel):
    messages: List[Dict[str, str]]
    mode: str = "researcher"
    use_web_search: bool = False


@app.post("/chat")
async def chat_endpoint(request: ChatRequest):
    try:
        latest_question = request.messages[-1]["content"]
        local_context = kb.query(latest_question)
        final_context = f"【本地PDF资料库】：\n{local_context}\n"

        # 🌟 网页端大脑升级：也赋予它全球化视野
        system_prompt = "你是一个具有国际视野的全能 AI 智能体（Agent）。在进行联网搜索时，请优先使用英文关键词检索全球权威媒体的一手资讯。你可以自主决定是否需要联网搜索、存盘或发微信。请一步步调用对应工具完成复杂任务。必须通过标准的 tool_calls 接口进行调用。"

        api_messages = [{"role": "system", "content": system_prompt}]
        for i, msg in enumerate(request.messages):
            if i == len(request.messages) - 1:
                api_messages.append(
                    {"role": "user", "content": f"已知情报：\n{final_context}\n\n我的最新任务是：{msg['content']}"})
            else:
                api_messages.append({"role": msg["role"], "content": msg["content"]})

        answer = run_agent_loop(api_messages)
        return {"answer": answer}

    except Exception as e:
        return {"answer": f"系统故障：{str(e)}"}


@app.post("/upload")
async def upload_file(file: UploadFile = File(...)):
    try:
        temp_file_path = f"./temp_{file.filename}"
        with open(temp_file_path, "wb+") as file_object:
            shutil.copyfileobj(file.file, file_object)
        kb.ingest_pdf(temp_file_path)
        os.remove(temp_file_path)
        return {"status": "success", "message": f"成功吞噬文件：{file.filename}！"}
    except Exception as e:
        return {"status": "error", "message": str(e)}


