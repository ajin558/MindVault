def run_agent_loop(api_messages: list) -> str:
    MAX_STEPS = 6
    step = 0
    while step < MAX_STEPS:
        logger.info(f"🧠 大脑正在进行第 {step + 1} 轮思考...")
        response = client_llm.chat.completions.create(
            model="deepseek-chat", messages=api_messages, tools=agent_tools, tool_choice="auto"
        )
        response_message = response.choices[0].message

        if not response_message.tool_calls:
            logger.info("✨ 思考结束，任务完成！")
            return response_message.content

        logger.info("⚡ 拦截到工具调用请求！准备执行动作！")
        api_messages.append(response_message)

        for tool_call in response_message.tool_calls:
            function_name = tool_call.function.name
            try:
                arguments = json.loads(tool_call.function.arguments)
            except json.JSONDecodeError:
                arguments = {}

            logger.info(f"   -> 🤖 正在调用武器: {function_name}")

            if function_name == "search_web":
                tool_result = search_web(arguments.get("query", ""))
            elif function_name == "save_report_to_disk":
                tool_result = save_report_to_disk(arguments.get("filename", "report.md"), arguments.get("content", ""))
            elif function_name == "send_wechat_push":
                tool_result = send_wechat_push(arguments.get("title", "系统通知"), arguments.get("content", ""))
            elif function_name == "query_business_data":
                tool_result = query_business_data(arguments.get("metric", ""))
            else:
                tool_result = f"错误：未知的工具 {function_name}"

            api_messages.append(
                {"role": "tool", "tool_call_id": tool_call.id, "name": function_name, "content": tool_result})
        step += 1
    return "Agent 执行步数超限，任务被强制终止。"


